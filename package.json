{
  "name": "ringport",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:cleanup": "prisma db execute --file scripts/migrate-plan-manager-cleanup.sql --schema=prisma/schema.prisma",
    "db:patches": "prisma db execute --file scripts/migrate-credit-buckets.sql --schema=prisma/schema.prisma && prisma db execute --file scripts/migrate-ringport-brand.sql --schema=prisma/schema.prisma",
    "db:postdeploy": "npm run db:cleanup && npm run db:patches",
    "db:baseline": "prisma migrate resolve --applied 20260722000000_baseline",
    "db:deploy": "node scripts/prisma-migrate-deploy.js && npm run db:postdeploy",
    "db:local": "bash scripts/start-local-postgres.sh",
    "db:init": "prisma generate && prisma migrate dev",
    "db:backfill-bookings": "node scripts/backfill-bookings.js",
    "check": "node scripts/release-check.js",
    "db:migrate-sqlite": "bash -c 'source scripts/use-node-22.sh && node scripts/migrate-sqlite-to-postgres.js \"$@\"' --",
    "test:booking": "node scripts/test-booking-stack.js",
    "test:telnyx": "node scripts/test-telnyx-suite.js",
    "test:telnyx-media": "node scripts/test-telnyx-media-bridge.js",
    "test:onboarding-media": "node scripts/test-onboarding-media-bridge.js"
  },
  "keywords": [
    "gemini",
    "live-api",
    "receptionist",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@prisma/client": "6.19.3",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide": "^1.21.0",
    "luxon": "^3.7.2",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "read-excel-file": "^9.2.0",
    "stripe": "^22.3.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "6.19.3"
  }
}
