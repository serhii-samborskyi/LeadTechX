generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model BusinessProfile {
  id                 Int                    @id @default(autoincrement())
  cacheKey           String                 @unique
  businessName       String
  website            String?
  normalized         String
  summary            String
  hours              String?
  services           String?
  serviceArea        String?
  contact            String?
  rawData            Json
  systemPrompt       String
  researchModel      String
  sourceUrls         Json?
  accountStatus      String                 @default("unclaimed")
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  creditBalance      Int                    @default(0)
  stripeCustomerId   String?
  stripeSubscriptionId String?
  stripeSubscriptionStatus String?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionPlanId Int?
  subscriptionPlan   SubscriptionPlan?    @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  leadWebhookToken   String?                @unique
  leadWebhookEnabled Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  config             BusinessConfig?
  users              User[]
  voiceNumbers       VoiceNumber[]
  voiceCalls         VoiceCall[]
  leads              Lead[]
  fastAgentSessions  FastAgentSession[]
  claimTokens        AccountClaimToken[]
  demoAssignments    DemoNumberAssignment[]
  onboardingSessions OnboardingSession[]
  customerFeedback    CustomerFeedback[]
  leadWebhookEvents   LeadWebhookEvent[]
  messageDeliveries   MessageDelivery[]
  usageEvents         UsageEvent[]
  creditTransactions  CreditTransaction[]
  stripeCheckoutSessions StripeCheckoutSession[]
  inboundMessages    MessageInbound[]
}

model SubscriptionPlan {
  id                Int              @id @default(autoincrement())
  name              String
  slug              String           @unique
  description       String?
  monthlyPriceCents Int              @default(0)
  monthlyCredits    Int              @default(0)
  stripePriceId     String?
  active            Boolean          @default(true)
  sortOrder         Int              @default(0)
  businessProfiles  BusinessProfile[]
  checkoutSessions  StripeCheckoutSession[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([active, sortOrder])
}

model BusinessConfig {
  id                  Int                @id @default(autoincrement())
  businessProfileId   Int                @unique
  businessProfile     BusinessProfile    @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  extraInstructions   String             @default("")
  qualificationInstructions String        @default("You are an outbound lead qualification agent. Confirm you are speaking with the lead, ask if now is a good time, confirm what they need, urgency, location or service area, budget or price expectations when relevant, and whether they want an appointment or callback. Keep the call brief, professional, and honest.")
  qualificationEnabled Boolean            @default(true)
  qualificationLaunchMode String          @default("approval")
  qualificationDelayMinSeconds Int        @default(30)
  qualificationDelayMaxSeconds Int        @default(100)
  qualificationMaxAttempts Int            @default(3)
  qualificationRetryDelayMinutes Int       @default(120)
  leadWebhookDedupeWindowHours Int         @default(24)
  reviewRequestsEnabled Boolean            @default(false)
  reviewLink          String             @default("")
  reviewPromptInstructions String         @default("After a completed service or appointment, ask whether the customer is happy with the service. If they are happy, offer to text the review link. If they are not happy, apologize, collect the issue, and escalate it to management.")
  reviewRequestTemplate String            @default("Thank you for choosing {{business_name}}. If you were happy with the service, please leave us a review: {{review_link}}")
  complaintRecoveryInstructions String     @default("Apologize, collect what happened, ask what resolution they want, and tell the customer management will be notified.")
  complaintEscalationTemplate String       @default("Complaint for {{business_name}}. Customer: {{customer_name}}. Phone: {{customer_phone}}. Issue: {{complaint}}")
  managerNotificationPhone String          @default("")
  missedCallFollowupTemplate String        @default("Sorry we missed your call to {{business_name}}. Reply here and we will help.")
  appointmentReminderTemplate String       @default("Reminder: you have an appointment with {{business_name}} on {{appointment_time}}. Reply if you need to reschedule.")
  appointmentMode     String             @default("instant")
  slotDurationMinutes Int                @default(30)
  bufferMinutes       Int                @default(0)
  timezone            String             @default("America/Chicago")
  calendarProvider    String             @default("internal")
  providerConfig      Json?
  voiceName           String             @default("Puck")
  language            String             @default("English")
  agentName           String             @default("Alex")
  intakeFields        IntakeField[]
  knowledgeEntries    KnowledgeEntry[]
  priceEntries        PriceEntry[]
  availabilityRules   AvailabilityRule[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model IntakeField {
  id               Int            @id @default(autoincrement())
  businessConfigId Int
  businessConfig   BusinessConfig @relation(fields: [businessConfigId], references: [id], onDelete: Cascade)
  fieldKey         String
  label            String
  fieldType        String         @default("text")
  required         Boolean        @default(false)
  options          Json?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([businessConfigId, fieldKey])
}

model KnowledgeEntry {
  id               Int            @id @default(autoincrement())
  businessConfigId Int
  businessConfig   BusinessConfig @relation(fields: [businessConfigId], references: [id], onDelete: Cascade)
  question         String
  answer           String
  category         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model PriceEntry {
  id               Int            @id @default(autoincrement())
  businessConfigId Int
  businessConfig   BusinessConfig @relation(fields: [businessConfigId], references: [id], onDelete: Cascade)
  item             String
  description      String?
  priceType        String         @default("fixed")
  amountMin        Float?
  amountMax        Float?
  currency         String         @default("USD")
  category         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model AvailabilityRule {
  id               Int            @id @default(autoincrement())
  businessConfigId Int
  businessConfig   BusinessConfig @relation(fields: [businessConfigId], references: [id], onDelete: Cascade)
  dayOfWeek        Int
  startTime        String         @default("09:00")
  endTime          String         @default("17:00")
  enabled          Boolean        @default(true)

  @@unique([businessConfigId, dayOfWeek])
}

model Appointment {
  id               Int       @id @default(autoincrement())
  businessName     String
  website          String?
  customerName     String
  phone            String?
  email            String?
  requestedAt      String
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  durationMinutes  Int?
  timezone         String?
  intakeData       Json?
  calendarProvider String    @default("internal")
  bookingKey       String?   @unique
  externalId       String?
  reason           String?
  status           String    @default("requested")
  createdAt        DateTime  @default(now())
  feedback          CustomerFeedback[]
  messageDeliveries MessageDelivery[]
  inboundMessages    MessageInbound[]
}

model Lead {
  id                Int              @id @default(autoincrement())
  businessName      String
  website           String?
  businessProfileId Int?
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  voiceCallId       Int?             @unique
  voiceCall         VoiceCall?       @relation(fields: [voiceCallId], references: [id], onDelete: SetNull)
  name              String
  phone             String?
  email             String?
  need              String?
  status            String           @default("new")
  source            String           @default("agent")
  summary           String?
  transcript        String?
  notes             String?
  extractedFields   Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  qualificationCalls OutboundQualificationCall[]
  feedback          CustomerFeedback[]
  leadWebhookEvents LeadWebhookEvent[]
  messageDeliveries MessageDelivery[]
  inboundMessages    MessageInbound[]
  usageEvents       UsageEvent[]

  @@index([businessProfileId, createdAt])
  @@index([phone, createdAt])
  @@index([status, createdAt])
}

model TransferMessage {
  id           Int      @id @default(autoincrement())
  businessName String
  website      String?
  name         String?
  phone        String?
  email        String?
  message      String
  urgency      String?
  createdAt    DateTime @default(now())
}

model AppSettings {
  id                      Int      @id @default(1)
  researchModel           String   @default("gemini-3.1-pro-preview")
  liveModel               String   @default("models/gemini-3.1-flash-live-preview")
  voiceName               String   @default("Puck")
  language                String   @default("English")
  agentName               String   @default("Alex")
  platformBusinessRules   String   @default("Use only the language configured for the business agent. Do not switch languages automatically when the caller speaks another language. If the caller asks for another language, explain briefly in the configured language that the receptionist is set to use only that language unless the business changes settings.")
  publicBaseUrl           String   @default("")
  trialDays               Int      @default(7)
  claimLinkDays           Int      @default(30)
  trialCredits            Int      @default(900)
  tokenUsd                Float    @default(0.01)
  lowBalanceTokens        Int      @default(100)
  voiceMinuteCredits      Int      @default(10)
  geminiMinuteCredits     Int      @default(10)
  outboundCallCredits     Int      @default(20)
  messageCredits          Int      @default(5)
  stripeCreditPackCredits Int      @default(1000)
  recordingRetentionDays  Int      @default(30)
  demoNumberCapacity      Int      @default(10)
  demoCallerLimit         Int      @default(3)
  smtpHost                String   @default("")
  smtpPort                Int      @default(587)
  smtpSecure              Boolean  @default(false)
  smtpFromEmail           String   @default("")
  smtpFromName            String   @default("AI Receptionist")
  onboardingLookupUrl     String   @default("")
  onboardingVoiceName     String   @default("Puck")
  onboardingInstructions  String   @default("You are the AI Receptionist platform onboarding specialist. Collect the company name and website, text those details to the caller for confirmation, build the agent only after confirmation, and send the secure setup link when it is ready. Keep the call brief.")
  onboardingRecordCalls   Boolean  @default(false)
  onboardingTranscription Boolean  @default(true)
  messagePrimaryProvider  String   @default("bluebubbles")
  messageFailoverProvider String   @default("sentdm")
  blueBubblesBaseUrl      String   @default("")
  blueBubblesSendPath     String   @default("/api/v1/message/text")
  sentDmTemplateId        String   @default("")
  sentDmTemplateName      String   @default("")
  sentDmProfileId         String   @default("")
  updatedAt               DateTime @updatedAt
}

model User {
  id                Int              @id @default(autoincrement())
  email             String           @unique
  passwordHash      String
  name              String?
  role              String           @default("business")
  businessProfileId Int?
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  active            Boolean          @default(true)
  sessions          Session[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SystemSecret {
  id        Int      @id @default(autoincrement())
  secretKey String   @unique
  encrypted String
  hint      String?
  updatedAt DateTime @updatedAt
}

model VoiceNumber {
  id                Int                    @id @default(autoincrement())
  provider          String                 @default("telnyx")
  providerNumberId  String                 @unique
  phoneNumber       String                 @unique
  status            String                 @default("active")
  numberType        String                 @default("regular")
  label             String?
  connectionId      String?
  businessProfileId Int?
  businessProfile   BusinessProfile?       @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  demoAssignments   DemoNumberAssignment[]
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

model FastAgentSession {
  id                Int             @id @default(autoincrement())
  tokenHash         String          @unique
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  expiresAt         DateTime
  lastUsedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
}

model AccountClaimToken {
  id                Int             @id @default(autoincrement())
  tokenHash         String          @unique
  email             String?
  businessProfileId Int
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime        @default(now())

  @@index([email])
}

model DemoNumberAssignment {
  id                Int                 @id @default(autoincrement())
  voiceNumberId     Int
  voiceNumber       VoiceNumber         @relation(fields: [voiceNumberId], references: [id], onDelete: Cascade)
  businessProfileId Int                 @unique
  businessProfile   BusinessProfile     @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  status            String              @default("waiting")
  expiresAt         DateTime
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  callerBindings    DemoCallerBinding[]

  @@index([voiceNumberId, status, expiresAt])
}

model DemoCallerBinding {
  id                     Int                  @id @default(autoincrement())
  demoNumberAssignmentId Int
  demoNumberAssignment   DemoNumberAssignment @relation(fields: [demoNumberAssignmentId], references: [id], onDelete: Cascade)
  callerPhone            String               @unique
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([demoNumberAssignmentId, callerPhone])
}

model VoiceCall {
  id                Int                @id @default(autoincrement())
  provider          String             @default("telnyx")
  callControlId     String             @unique
  callSessionId     String?
  fromNumber        String?
  toNumber          String?
  status            String             @default("initiated")
  hangupCause       String?
  lastError         String?
  callMode          String             @default("business")
  recordingUrl      String?
  transcript        String?
  healthFlags       Json?
  metrics           Json?
  businessProfileId Int?
  businessProfile   BusinessProfile?   @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  startedAt         DateTime           @default(now())
  answeredAt        DateTime?
  endedAt           DateTime?
  updatedAt         DateTime           @updatedAt
  events            VoiceCallEvent[]
  onboardingSession OnboardingSession?
  lead              Lead?
  outboundQualificationCall OutboundQualificationCall?
  feedback          CustomerFeedback[]
  messageDeliveries MessageDelivery[]
  inboundMessages    MessageInbound[]
  usageEvents       UsageEvent[]
}

model OutboundQualificationCall {
  id                Int              @id @default(autoincrement())
  leadId            Int
  lead              Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  voiceCallId       Int?             @unique
  voiceCall         VoiceCall?       @relation(fields: [voiceCallId], references: [id], onDelete: SetNull)
  attemptNumber     Int              @default(1)
  status            String           @default("queued")
  resultStatus      String?
  fromNumber        String?
  toNumber          String
  summary           String?
  transcript        String?
  notes             String?
  extractedFields   Json?
  lastError         String?
  scheduledFor      DateTime?
  startedAt         DateTime?
  answeredAt        DateTime?
  endedAt           DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([leadId, createdAt])
  @@index([status, createdAt])
}

model OnboardingSession {
  id                   Int              @id @default(autoincrement())
  voiceCallId          Int              @unique
  voiceCall            VoiceCall        @relation(fields: [voiceCallId], references: [id], onDelete: Cascade)
  callerPhone          String
  campaignLabel        String?
  status               String           @default("started")
  businessName         String?
  website              String?
  email                String?
  lookupData           Json?
  businessProfileId    Int?
  businessProfile      BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  personaSwitchedAt    DateTime?
  claimLinkSentAt      DateTime?
  messageProvider      String?
  recordingEnabled     Boolean          @default(false)
  transcriptionEnabled Boolean          @default(true)
  transcript           String?
  summary              String?
  lastError            String?
  completedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([callerPhone, createdAt])
  @@index([campaignLabel, createdAt])
}

model MessageDelivery {
  id                 Int               @id @default(autoincrement())
  provider           String
  purpose            String
  toPhone            String
  status             String            @default("queued")
  providerMessageId  String?
  detail             Json?
  error              String?
  businessProfileId  Int?
  businessProfile    BusinessProfile?  @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  leadId             Int?
  lead               Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  voiceCallId        Int?
  voiceCall          VoiceCall?        @relation(fields: [voiceCallId], references: [id], onDelete: SetNull)
  appointmentId      Int?
  appointment        Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customerFeedbackId Int?
  customerFeedback   CustomerFeedback? @relation(fields: [customerFeedbackId], references: [id], onDelete: SetNull)
  usageEvents        UsageEvent[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([toPhone, createdAt])
  @@index([businessProfileId, createdAt])
  @@index([purpose, createdAt])
  @@index([appointmentId, createdAt])
}

model MessageInbound {
  id                Int              @id @default(autoincrement())
  provider          String
  eventType         String           @default("new-message")
  fromPhone         String?
  toPhone           String?
  chatGuid          String?
  providerMessageId String?
  text              String?
  status            String           @default("received")
  purpose           String?
  raw               Json?
  normalized        Json?
  error             String?
  businessProfileId Int?
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  leadId            Int?
  lead              Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  voiceCallId       Int?
  voiceCall         VoiceCall?       @relation(fields: [voiceCallId], references: [id], onDelete: SetNull)
  appointmentId     Int?
  appointment       Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([provider, providerMessageId])
  @@index([fromPhone, createdAt])
  @@index([chatGuid, createdAt])
  @@index([businessProfileId, createdAt])
  @@index([voiceCallId, createdAt])
  @@index([status, createdAt])
}

model CustomerFeedback {
  id                   Int               @id @default(autoincrement())
  businessProfileId    Int
  businessProfile      BusinessProfile   @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  leadId               Int?
  lead                 Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  voiceCallId          Int?
  voiceCall            VoiceCall?        @relation(fields: [voiceCallId], references: [id], onDelete: SetNull)
  appointmentId        Int?
  appointment          Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customerName         String?
  phone                String?
  email                String?
  sentiment            String            @default("unknown")
  rating               Int?
  feedbackText         String?
  status               String            @default("captured")
  reviewLink           String?
  reviewRequestedAt    DateTime?
  complaintEscalatedAt DateTime?
  resolvedAt           DateTime?
  messageDeliveries    MessageDelivery[]
  metadata             Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([businessProfileId, createdAt])
  @@index([leadId, createdAt])
  @@index([status, createdAt])
}

model LeadWebhookEvent {
  id                Int              @id @default(autoincrement())
  businessProfileId Int?
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  leadId            Int?
  lead              Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  token             String?
  status            String           @default("received")
  dedupeKey         String?
  normalized        Json?
  payload           Json?
  qualification     Json?
  error             String?
  createdAt         DateTime         @default(now())

  @@index([businessProfileId, createdAt])
  @@index([dedupeKey, createdAt])
  @@index([status, createdAt])
}

model UsageEvent {
  id                Int                @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile    @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  leadId            Int?
  lead              Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  voiceCallId       Int?
  voiceCall         VoiceCall?         @relation(fields: [voiceCallId], references: [id], onDelete: SetNull)
  messageDeliveryId Int?
  messageDelivery   MessageDelivery?   @relation(fields: [messageDeliveryId], references: [id], onDelete: SetNull)
  category          String
  provider          String?
  quantity          Float              @default(1)
  unit              String             @default("event")
  credits           Int                @default(0)
  metadata          Json?
  createdAt         DateTime           @default(now())
  creditTransaction CreditTransaction?

  @@index([businessProfileId, createdAt])
  @@index([category, createdAt])
}

model CreditTransaction {
  id                Int              @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile  @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  usageEventId      Int?             @unique
  usageEvent        UsageEvent?      @relation(fields: [usageEventId], references: [id], onDelete: SetNull)
  type              String
  amount            Int
  balanceAfter      Int
  note              String?
  metadata          Json?
  createdAt         DateTime         @default(now())

  @@index([businessProfileId, createdAt])
  @@index([type, createdAt])
}

model StripeCheckoutSession {
  id                Int              @id @default(autoincrement())
  businessProfileId Int
  businessProfile   BusinessProfile  @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  subscriptionPlanId Int?
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  stripeSessionId   String           @unique
  mode              String
  status            String           @default("created")
  creditAmount      Int              @default(0)
  amountTotal       Int?
  currency          String?
  stripeCustomerId  String?
  stripeSubscriptionId String?
  url               String?
  metadata          Json?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([businessProfileId, createdAt])
  @@index([subscriptionPlanId, createdAt])
  @@index([status, createdAt])
}

model StripeWebhookEvent {
  id              Int      @id @default(autoincrement())
  stripeEventId   String   @unique
  eventType       String
  payload         Json?
  processedAt     DateTime?
  error           String?
  createdAt       DateTime @default(now())

  @@index([eventType, createdAt])
}

model VoiceCallEvent {
  id          Int       @id @default(autoincrement())
  voiceCallId Int
  voiceCall   VoiceCall @relation(fields: [voiceCallId], references: [id], onDelete: Cascade)
  eventType   String
  detail      Json?
  createdAt   DateTime  @default(now())
}

model TelnyxWebhookEvent {
  id         Int      @id @default(autoincrement())
  webhookId  String   @unique
  eventType  String
  payload    Json?
  receivedAt DateTime @default(now())
}
